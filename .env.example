# Application
PORT=3000
HOST=localhost

# JWT (required)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_REMEMBER_ME_EXPIRES_IN=30d

# Seed admin (used by: npm run db:seed)
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@teacherlesson.local
ADMIN_PASSWORD=Admin@123

# Database (MYSQL_DATABASE = database name only, NOT a full URL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=teacher_lesson_blog
